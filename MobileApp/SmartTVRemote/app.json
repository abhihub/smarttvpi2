{
  "expo": {
    "name": "SmartTV Remote",
    "slug": "first-ship-1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/sample_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/sample_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/sample_icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.smarttvremote",
      "minSdkVersion": 24,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CAMERA",
        "VIBRATE"
      ],
      "usesCleartextTraffic": true,
      "allowBackup": false,
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "daksh-123",
    "extra": {
      "eas": {
        "projectId": "84a99270-f1a7-4e60-8ad4-18b4274bd728"
      }
    }
  }
}
